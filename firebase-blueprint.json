{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A web service or application link shared by teachers.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the service" },
        "description": { "type": "string", "description": "A brief description of the service" },
        "url": { "type": "string", "format": "uri", "description": "The URL of the service" },
        "category": { "type": "string", "description": "The category of the service (e.g., class, admin)" },
        "ownerId": { "type": "string", "description": "The UID of the user who created this service" },
        "clickCount": { "type": "integer", "description": "Number of times the service was clicked" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "updatedAt": { "type": "number", "description": "Timestamp of last update" }
      },
      "required": ["name", "url", "category", "ownerId", "createdAt"]
    },
    "GlobalStats": {
      "title": "GlobalStats",
      "description": "Global portal statistics",
      "type": "object",
      "properties": {
        "visitCount": { "type": "integer", "description": "Total number of portal visits" }
      },
      "required": ["visitCount"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "An error report or support inquiry submitted by users.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Subject of the inquiry" },
        "content": { "type": "string", "description": "Detailed description of the issue or question" },
        "category": { "type": "string", "description": "Type of inquiry (error, feature, general)" },
        "contact": { "type": "string", "description": "User's email or phone number for reply" },
        "userName": { "type": "string", "description": "Name of the submitter" },
        "createdAt": { "type": "number", "description": "Submission timestamp" },
        "status": { "type": "string", "description": "Current status (pending, in_progress, resolved)", "enum": ["pending", "in_progress", "resolved"] }
      },
      "required": ["title", "content", "category", "createdAt", "status"]
    }
  },
  "firestore": {
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of all shared web services."
    },
    "/stats/{statId}": {
      "schema": "GlobalStats",
      "description": "Global statistics like visit counts."
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "User feedback, error reports, and inquiry tickets."
    }
  }
}
