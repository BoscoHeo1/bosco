rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'heoalchan@goedu.kr';
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'url', 'category', 'ownerId', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.url is string && data.url.size() > 0 && data.url.size() <= 500 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.createdAt is number;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['title', 'content', 'category', 'createdAt', 'status']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.createdAt is number &&
             data.status is string && (data.status == 'pending' || data.status == 'in_progress' || data.status == 'resolved') &&
             (!data.keys().hasAny(['contact']) || (data.contact is string && data.contact.size() <= 200)) &&
             (!data.keys().hasAny(['userName']) || (data.userName is string && data.userName.size() <= 100));
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidService(request.resource.data) && isValidId(serviceId);
      allow update: if (isAdmin() && 
                    isValidService(request.resource.data) &&
                    request.resource.data.ownerId == resource.data.ownerId &&
                    request.resource.data.createdAt == resource.data.createdAt) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount']) &&
                     request.resource.data.clickCount == resource.data.get('clickCount', 0) + 1);
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data) && isValidId(inquiryId);
      allow read, update, delete: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if true;
      allow update: if statId == 'portal' &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visitCount']) &&
                    request.resource.data.visitCount == resource.data.get('visitCount', 0) + 1;
      // Allow creation of the portal stat doc if it doesn't exist (initialization)
      allow create: if statId == 'portal' && 
                    ((request.resource.data.keys().hasAll(['visitCount']) && 
                      request.resource.data.keys().size() == 1 && 
                      request.resource.data.visitCount == 1) || isAdmin());
    }
  }
}
